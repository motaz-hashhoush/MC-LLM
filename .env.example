# MC-LLM Environment Configuration
# Copy this file to .env and adjust values as needed.

# ── Model ────────────────────────────────────────────────────────────────────
# Change this to any HuggingFace model identifier you want to serve.
# Examples:
#   MODEL_NAME=Qwen/Qwen3-14B
#   MODEL_NAME=meta-llama/Llama-3-8B
#   MODEL_NAME=mistralai/Mistral-7B-Instruct-v0.3
MODEL_NAME=Qwen/Qwen3-0.6B
#Qwen/Qwen3-14B

# ── vLLM ─────────────────────────────────────────────────────────────────────
VLLM_ENDPOINT=http://vllm:8000

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ── PostgreSQL (external / local instance) ───────────────────────────────────
# Point this to your local or separate PostgreSQL server.
# When running inside Docker, use host.docker.internal to reach the host machine.
DATABASE_URL=postgresql+asyncpg://llm_user:llm_pass@localhost:5432/llm_logs
#postgresql+asyncpg://llm_user:llm_pass@host.docker.internal:5432/llm_logs

# ── Inference Defaults ───────────────────────────────────────────────────────
MAX_TOKENS=512
TEMPERATURE=0.7

# ── Ray ──────────────────────────────────────────────────────────────────────
RAY_HEAD_ADDRESS=ray://ray-head:10001
RAY_MIN_REPLICAS=1
RAY_MAX_REPLICAS=4

# ── Debug ────────────────────────────────────────────────────────────────────
DEBUG=false
