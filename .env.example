# MC-LLM Environment Configuration
# Copy this file to .env and adjust values as needed.

# ── Model ────────────────────────────────────────────────────────────────────
MODEL_NAME=Qwen/Qwen2.5-7B-Instruct
MAX_MODEL_LEN=8192

# ── vLLM ─────────────────────────────────────────────────────────────────────
VLLM_ENDPOINT=http://vllm:8000
GPU_MEM_UTIL=0.60
DTYPE=float16

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ── PostgreSQL ───────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# ── Inference Defaults ───────────────────────────────────────────────────────
MAX_TOKENS=512
TEMPERATURE=0.3

# ── Debug ────────────────────────────────────────────────────────────────────
DEBUG=false

# ── Speech-to-Text ───────────────────────────────────────────────────────────
STT_DEVICE=cuda                       # "cuda" for GPU, "cpu" for CPU-only
STT_COMPUTE_TYPE=float16              # float16 (GPU) | int8 (CPU) | float32
STT_MAX_AUDIO_MB=25                   # max upload size in MB
STT_LANGUAGE=ar                       # ISO 639-1 lang code: ar=Arabic, en=English
STT_MODEL_NAME=deepdml/faster-whisper-large-v3-turbo-ct2
STT_MODEL_PATH=/models/deepdml/faster-whisper-large-v3-turbo-ct2
